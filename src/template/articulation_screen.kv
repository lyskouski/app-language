#:kivy 2.0
#:import RecorderWidget component.recorder_widget
#:import CBoxLayout carbonkivy.uix.boxlayout.CBoxLayout

<ArticulationScreen>:
    CBoxLayout:
        orientation: 'vertical'

        ActionBar:
            height: dp(48)
            ActionView:
                use_separator: True
                ActionPrevious:
                    with_previous: True
                    on_release: app.next_screen('main_screen')
                    title: app._('game_articulation', app.locale)

        RecorderWidget:
            orientation: 'horizontal'
            padding: 10
            spacing: 10
