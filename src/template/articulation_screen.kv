#:import RecorderWidget component.recorder_widget

<ArticulationScreen>:
    BoxLayout:
        orientation: 'vertical'

        ActionBar:
            height: app.theme.md3_button_height + dp(4)
            ActionView:
                use_separator: True
                ActionPrevious:
                    with_previous: True
                    on_release: app.next_screen('main_screen')
                    title: app._('game_articulation', app.locale)

        RecorderWidget:
            orientation: 'horizontal'
            padding: 10
            spacing: 10

<MultilineLabel>:
    size_hint_y: None
    height: self.texture_size[1]
    text_size: self.width, None
    halign: "left"
    valign: "middle"
