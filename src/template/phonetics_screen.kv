#:import PhoneticsWidget component.phonetics_widget

<PhoneticsScreen>:
    BoxLayout:
        orientation: 'vertical'

        ActionBar:
            height: app.theme.md3_button_height
            ActionView:
                use_separator: True
                ActionPrevious:
                    with_previous: True
                    on_release: app.next_screen('main_screen')
                    title: app._('game_phonetics', app.locale)
                ActionButton:
                    text: app._('button_clear', app.locale)
                    on_release: app.next_screen('phonetics_screen')
                ActionButton:
                    text: app._('button_shuffle', app.locale)
                    on_release:
                        app.init_store(force_shuffle=True)
                        app.refresh_widgets()

        Accordion:
            AccordionItem:
                title: "%s & %s" % (app.locale_to, app.locale_from)
                collapse: False
                BoxLayout:
                    PhoneticsWidget:
                        origin: True
                        secondary: True
            AccordionItem:
                title: "%s -> %s" % (app.locale_to, app.locale_to)
                collapse: True
                BoxLayout:
                    PhoneticsWidget:
                        origin: True
                        secondary: False
            AccordionItem:
                title: "%s -> %s" % (app.locale_to, app.locale_from)
                collapse: True
                BoxLayout:
                    PhoneticsWidget:
                        origin: False
                        secondary: True
