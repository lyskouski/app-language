#:kivy 2.0
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDTopAppBar kivymd.uix.toolbar.MDTopAppBar
#:import PhoneticsWidget component.phonetics_widget

<PhoneticsScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        MDTopAppBar:
            hidden: app.is_mobile
            opacity: 1.0 if not app.is_mobile else 0
            height: '56dp' if not app.is_mobile else 0
            title: app._('game_phonetics', app.locale)
            left_action_items: [["arrow-left", lambda x: app.next_screen('main_screen')]]

        MDBoxLayout:
            orientation: 'vertical'
            padding: dp(5)
            spacing: dp(5)

            PhoneticsWidget:
                origin: True
                secondary: True

        MDTopAppBar:
            hidden: False if app.is_mobile else True
            opacity: 1.0 if app.is_mobile else 0
            height: '56dp' if app.is_mobile else 0
            title: app._('game_phonetics', app.locale)
            left_action_items: [["arrow-left", lambda x: app.next_screen('main_screen')]]
