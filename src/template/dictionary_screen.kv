#:kivy 2.0
#:import HarmonicaWidget component.harmonica_widget
#:import CBoxLayout carbonkivy.uix.boxlayout.CBoxLayout

<DictionaryScreen>:
    CBoxLayout:
        orientation: 'vertical'
        ActionBar:
            height: dp(48)
            ActionView:
                use_separator: True
                ActionPrevious:
                    with_previous: True
                    on_release: app.next_screen('main_screen')
                    title: app._('game_harmonica', app.locale)
                ActionButton:
                    text: app._('button_clear', app.locale)
                    color: 1, 1, 1, 1
                    on_release: app.next_screen('dictionary_screen')
                ActionButton:
                    text: app._('button_shuffle', app.locale)
                    color: 1, 1, 1, 1
                    on_release:
                        app.init_store(force_shuffle=True)
                        app.refresh_widgets()
        Accordion:
            AccordionItem:
                title: "%s & %s" % (app.locale_to, app.locale_from)
                collapse: False
                BoxLayout:
                    HarmonicaWidget:
                        origin: True
                        secondary: True
            AccordionItem:
                title: "%s -> %s" % (app.locale_to, app.locale_from)
                collapse: True
                BoxLayout:
                    HarmonicaWidget:
                        origin: True
                        secondary: False
            AccordionItem:
                title: "%s -> %s" % (app.locale_from, app.locale_to)
                collapse: True
                BoxLayout:
                    HarmonicaWidget:
                        origin: False
                        secondary: True
