#:kivy 2.0
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDScrollView kivymd.uix.scrollview.MDScrollView
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDLabel kivymd.uix.label.MDLabel
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton
#:import MDFlatButton kivymd.uix.button.MDFlatButton

<LanguagePairAddScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)

        # Header
        MDBoxLayout:
            size_hint_y: None
            height: dp(50)
            MDLabel:
                text: app._("language_pair_add_title", app.locale)
                font_style: "H5"
                bold: True

        # Form fields
        MDScrollView:
            size_hint_y: 0.8

            MDBoxLayout:
                orientation: 'vertical'
                spacing: dp(10)
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(8), 0]

                # Source Language - REQUIRED
                MDBoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(160)
                    spacing: dp(5)
                    MDLabel:
                        text: app._("language_pair_from_label", app.locale)
                        size_hint_y: None
                        height: dp(36)
                        font_style: "Button"
                        halign: 'left'
                    # Language selection tiles (dynamic)
                    RecycleView:
                        id: from_view
                        viewclass: 'LanguageTileWidget'
                        size_hint_y: None
                        height: dp(130)
                        RecycleGridLayout:
                            cols: 4
                            default_size: None, dp(70)
                            default_size_hint: 1, None
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)

                # Target Language - REQUIRED
                MDBoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(160)
                    spacing: dp(5)
                    MDLabel:
                        text: app._("language_pair_to_label", app.locale)
                        size_hint_y: None
                        height: dp(36)
                        font_style: "Button"
                        halign: 'left'
                    # Language selection tiles (dynamic)
                    RecycleView:
                        id: to_view
                        viewclass: 'LanguageTileWidget'
                        size_hint_y: None
                        height: dp(130)
                        RecycleGridLayout:
                            cols: 4
                            default_size: None, dp(70)
                            default_size_hint: 1, None
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(8)

                # Name - Auto-generated, but editable
                MDBoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    MDLabel:
                        text: app._("language_pair_name_label", app.locale)
                        size_hint_y: None
                        height: dp(36)
                        font_style: "Button"
                        halign: 'left'
                    MDTextField:
                        id: name_input
                        text: root.name_text
                        mode: "rectangle"
                        size_hint_y: None
                        height: dp(48)
                        on_text: root.name_text = self.text

                # Logo Path - Optional
                MDBoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    MDLabel:
                        text: app._("language_pair_logo_label", app.locale)
                        size_hint_y: None
                        height: dp(36)
                        font_style: "Button"
                        halign: 'left'
                    MDTextField:
                        id: logo_input
                        text: root.logo_path_text
                        mode: "rectangle"
                        size_hint_y: None
                        height: dp(48)
                        hint_text: "e.g., assets/images/language/pair_logo.png"
                        on_text: root.logo_path_text = self.text

        # Action buttons
        MDBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)
            MDFlatButton:
                text: app._("button_cancel", app.locale)
                on_release: root.cancel()
            MDRaisedButton:
                text: app._("button_save", app.locale)
                on_release: root.save_language_pair()


<LanguageTileWidget@ButtonBehavior+MDBoxLayout>:
    locale: ''
    text: ''
    logo: ''
    selected: False
    is_from: False
    orientation: 'vertical'
    padding: dp(8)
    spacing: dp(4)

    canvas.before:
        Color:
            rgba: (0.3, 0.7, 0.3, 1) if self.selected else (0.2, 0.2, 0.2, 0.8)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]

    on_release:
        # Call appropriate selection method based on is_from flag
        app.root.get_screen('language_pair_add_screen').select_from_language(self.locale) if self.is_from else app.root.get_screen('language_pair_add_screen').select_to_language(self.locale)

    MDLabel:
        text: root.locale
        font_style: "Button"
        bold: True
        size_hint_y: 0.4
        halign: "center"

    MDLabel:
        text: root.text
        font_style: "Caption"
        size_hint_y: 0.6
        halign: 'center'