<LanguagePairAddScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10

        # Header
        BoxLayout:
            size_hint_y: None
            height: 50
            Label:
                text: app._("language_pair_add_title", app.locale)
                font_size: '20sp'
                bold: True

        # Form fields
        ScrollView:
            size_hint_y: 0.8

            BoxLayout:
                orientation: 'vertical'
                spacing: 10
                size_hint_y: None
                height: self.minimum_height
                padding: [10, 0]

                # Source Language - REQUIRED
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 150
                    spacing: 5
                    Label:
                        text: app._("language_pair_from_label", app.locale)
                        size_hint_y: None
                        height: 30
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    # Language selection tiles (dynamic)
                    RecycleView:
                        id: from_view
                        viewclass: 'LanguageTileWidget'
                        size_hint_y: None
                        height: 110
                        RecycleGridLayout:
                            cols: 4
                            default_size: None, dp(50)
                            default_size_hint: 1, None
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(5)

                # Target Language - REQUIRED
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 150
                    spacing: 5
                    Label:
                        text: app._("language_pair_to_label", app.locale)
                        size_hint_y: None
                        height: 30
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    # Language selection tiles (dynamic)
                    RecycleView:
                        id: to_view
                        viewclass: 'LanguageTileWidget'
                        size_hint_y: None
                        height: 110
                        RecycleGridLayout:
                            cols: 4
                            default_size: None, dp(50)
                            default_size_hint: 1, None
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(5)

                # Name - Auto-generated, but editable
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 80
                    spacing: 5
                    Label:
                        text: app._("language_pair_name_label", app.locale)
                        size_hint_y: None
                        height: 30
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: name_input
                        text: root.name_text
                        multiline: False
                        size_hint_y: None
                        height: 40
                        on_text: root.name_text = self.text

                # Logo Path - Optional
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 80
                    spacing: 5
                    Label:
                        text: app._("language_pair_logo_label", app.locale)
                        size_hint_y: None
                        height: 30
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: logo_input
                        text: root.logo_path_text
                        multiline: False
                        size_hint_y: None
                        height: 40
                        hint_text: "e.g., assets/images/language/pair_logo.png"
                        on_text: root.logo_path_text = self.text

        # Action buttons
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 50
            spacing: 10
            Button:
                text: app._("button_cancel", app.locale)
                on_release: root.cancel()
            Button:
                text: app._("button_save", app.locale)
                on_release: root.save_language_pair()


<LanguageTileWidget@ButtonBehavior+BoxLayout>:
    locale: ''
    text: ''
    logo: ''
    selected: False
    is_from: False
    orientation: 'vertical'
    padding: dp(5)
    spacing: dp(2)

    canvas.before:
        Color:
            rgba: (0.3, 0.7, 0.3, 1) if self.selected else (0.2, 0.2, 0.2, 0.8)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]

    on_release:
        # Call appropriate selection method based on is_from flag
        app.root.get_screen('language_pair_add_screen').select_from_language(self.locale) if self.is_from else app.root.get_screen('language_pair_add_screen').select_to_language(self.locale)

    Label:
        text: root.locale
        font_size: sp(16)
        bold: True
        size_hint_y: 0.4
        color: (1, 1, 1, 1)

    Label:
        text: root.text
        font_size: sp(10)
        size_hint_y: 0.6
        text_size: self.width, None
        halign: 'center'
        color: (0.9, 0.9, 0.9, 1)