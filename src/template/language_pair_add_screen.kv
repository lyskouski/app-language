<LanguagePairAddScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)

        # Header
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            Label:
                text: app._("language_pair_add_title", app.locale)
                font_size: sp(20)
                bold: True

        # Form fields
        ScrollView:
            size_hint_y: 0.8

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(10)
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(8), 0]

                # Source Language - REQUIRED
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(5)
                    Label:
                        text: app._("language_pair_from_label", app.locale)
                        size_hint_y: None
                        height: dp(30)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    # Language selection dropdown
                    Spinner:
                        id: from_language
                        text: root.from_language_text if root.from_language_text else app._('language_pair_select_language', app.locale)
                        values: root.language_options
                        size_hint_y: 1
                        on_text: root.select_from_language(self.text)

                # Target Language - REQUIRED
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(5)
                    Label:
                        text: app._("language_pair_to_label", app.locale)
                        size_hint_y: None
                        height: dp(30)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    # Language selection dropdown
                    Spinner:
                        id: to_language
                        text: root.to_language_text if root.to_language_text else app._('language_pair_select_language', app.locale)
                        values: root.language_options
                        size_hint_y: 1
                        on_text: root.select_to_language(self.text)

                # Name - Auto-generated, but editable
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(75)
                    spacing: dp(5)
                    Label:
                        text: app._("language_pair_name_label", app.locale)
                        size_hint_y: None
                        height: dp(30)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: name_input
                        text: root.name_text
                        multiline: False
                        size_hint_y: 1
                        font_size: sp(16)
                        on_text: root.name_text = self.text

                # Logo Path - Optional
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(75)
                    spacing: dp(5)
                    Label:
                        text: app._("language_pair_logo_label", app.locale)
                        size_hint_y: None
                        height: dp(30)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: logo_input
                        text: root.logo_path_text
                        multiline: False
                        size_hint_y: 1
                        font_size: sp(14)
                        hint_text: "e.g., assets/images/language/pair_logo.png"
                        on_text: root.logo_path_text = self.text

        # Action buttons
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(45)
            spacing: dp(10)
            Button:
                text: app._("button_cancel", app.locale)
                font_size: sp(16)
                on_release: root.cancel()
            Button:
                text: app._("button_save", app.locale)
                font_size: sp(16)
                on_release: root.save_language_pair()
