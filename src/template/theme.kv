<ScreenManager>:
    canvas.before:
        Color:
            rgba: app.theme_color('md3_background', app.theme_version)
        Rectangle:
            pos: self.pos
            size: self.size

<Screen>:
    canvas.before:
        Color:
            rgba: app.theme_color('md3_surface', app.theme_version)
        Rectangle:
            pos: self.pos
            size: self.size

<Label>:
    color: app.theme_color('md3_on_surface', app.theme_version)

<TextInput>:
    size_hint_y: None
    height: app.theme.md3_textinput_height
    on_text_validate: app.focus_next_form_field(self)
    background_normal: ""
    background_active: ""
    background_disabled_normal: ""
    background_color: app.theme_color('md3_surface_container', app.theme_version) if not self.disabled else app.theme_color('md3_surface_variant', app.theme_version)
    foreground_color: app.theme_color('md3_on_surface', app.theme_version)
    hint_text_color: app.theme_color('md3_on_surface_variant', app.theme_version)
    cursor_color: app.theme_color('md3_primary', app.theme_version)
    padding: [dp(12), dp(10), dp(12), dp(10)]

<Button>:
    size_hint_y: None
    height: app.theme.md3_button_height
    background_normal: ""
    background_down: ""
    background_disabled_normal: ""
    background_disabled_down: ""
    background_color: app.theme_color('md3_primary', app.theme_version) if not self.disabled else app.theme_color('md3_outline', app.theme_version)
    color: app.theme_color('md3_on_primary', app.theme_version) if not self.disabled else app.theme_color('md3_surface', app.theme_version)

<Spinner>:
    size_hint_y: None
    height: app.theme.md3_textinput_height

<ToggleButton>:
    size_hint_y: None
    height: app.theme.md3_button_height
    background_normal: ""
    background_down: ""
    background_disabled_normal: ""
    background_disabled_down: ""
    background_color: app.theme_color('md3_secondary', app.theme_version) if self.state == 'normal' else app.theme_color('md3_primary', app.theme_version)
    color: app.theme_color('md3_on_secondary', app.theme_version) if self.state == 'normal' else app.theme_color('md3_on_primary', app.theme_version)

<Accordion>:
    canvas.before:
        Color:
            rgba: app.theme_color('md3_surface_container', app.theme_version)
        Rectangle:
            pos: self.pos
            size: self.size

<AccordionItem>:
    background_normal: "atlas://data/images/defaulttheme/button"
    background_selected: "atlas://data/images/defaulttheme/button_pressed"
    canvas.before:
        Color:
            rgba: app.theme_color('md3_surface', app.theme_version)
        Rectangle:
            pos: self.pos
            size: self.size

[AccordionItemTitle@Label]:
    text: ctx.title
    color: app.theme_color('md3_on_secondary', app.theme_version) if ctx.item.collapse else app.theme_color('md3_on_primary', app.theme_version)
    halign: 'center'
    valign: 'middle'
    text_size: None, None
    canvas.before:
        Color:
            rgba: app.theme_color('md3_secondary', app.theme_version) if ctx.item.collapse else app.theme_color('md3_primary', app.theme_version)
        Rectangle:
            pos: self.pos
            size: self.size
        PushMatrix
        Translate:
            xy: self.center_x, self.center_y
        Rotate:
            angle: 90 if ctx.item.orientation == 'horizontal' else 0
            axis: 0, 0, 1
        Translate:
            xy: -self.center_x, -self.center_y
    canvas.after:
        PopMatrix

<ActionBar>:
    background_image: ""
    background_color: app.theme_color('md3_primary', app.theme_version)

<ActionView>:
    background_image: ""
    background_color: app.theme_color('md3_primary', app.theme_version)
    spacing: dp(4)
    padding: [dp(4), dp(4), dp(4), dp(4)]

<ActionButton>:
    size_hint_y: None
    height: app.theme.md3_button_height - dp(8)
    background_normal: ""
    background_down: ""
    background_disabled_normal: ""
    background_disabled_down: ""
    background_color: app.theme_color('md3_secondary', app.theme_version) if not self.disabled else app.theme_color('md3_outline', app.theme_version)
    color: app.theme_color('md3_on_secondary', app.theme_version) if not self.disabled else app.theme_color('md3_surface', app.theme_version)

<ActionPrevious>:
    app_icon: "assets/images/logo_44.png"
    color: app.theme_color('md3_on_primary', app.theme_version)
