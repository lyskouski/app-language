<LanguagePairIOScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(12)
        spacing: dp(10)

        # Header
        BoxLayout:
            size_hint_y: None
            height: app.theme.md3_button_height
            spacing: dp(8)
            Button:
                text: app._('button_back', app.locale)
                size_hint_x: None
                width: dp(80)
                on_release: root.go_back()
            Label:
                text: app._('lang_pair_io_title', app.locale) + (' — ' + root.pair_name if root.pair_name else '')
                font_size: sp(18)
                bold: True
                halign: 'left'
                valign: 'middle'
                text_size: self.size

        # Mode toggle
        BoxLayout:
            size_hint_y: None
            height: app.theme.md3_button_height
            spacing: dp(8)
            ToggleButton:
                text: app._('lang_pair_export_btn', app.locale)
                group: 'io_mode'
                state: 'down' if root.export_mode else 'normal'
                on_release: root.export_mode = True
            ToggleButton:
                text: app._('lang_pair_import_btn', app.locale)
                group: 'io_mode'
                state: 'down' if not root.export_mode else 'normal'
                on_release: root.export_mode = False

        # File path input
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(8)
            Label:
                text: app._('lang_pair_file_path', app.locale)
                size_hint_x: None
                width: dp(80)
                halign: 'right'
                valign: 'middle'
                text_size: self.size
            TextInput:
                text: root.file_path
                multiline: False
                on_text: root.file_path = self.text
                hint_text: '/path/to/language_pair.json'
            Button:
                text: app._('lang_pair_browse_btn', app.locale)
                size_hint_x: None
                width: dp(88)
                on_release: root.open_file_chooser()

        # Import-only: merge option
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            opacity: 0 if root.export_mode else 1
            disabled: root.export_mode
            spacing: dp(8)
            CheckBox:
                active: root.merge_import
                size_hint_x: None
                width: dp(40)
                on_active: root.merge_import = self.active
            Label:
                text: app._('lang_pair_merge_import', app.locale)
                halign: 'left'
                valign: 'middle'
                text_size: self.size

        # Action button
        Button:
            size_hint_y: None
            height: app.theme.md3_button_height
            text: app._('lang_pair_export_btn', app.locale) if root.export_mode else app._('lang_pair_import_btn', app.locale)
            disabled: root.is_busy
            on_release:
                root.do_export() if root.export_mode else root.do_import()

        # Status label
        Label:
            text: root.status_text
            halign: 'left'
            valign: 'top'
            text_size: self.size
            size_hint_y: None
            height: dp(80)
            color: app.theme_color('md3_primary', app.theme_version)

        Widget:
