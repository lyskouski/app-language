<MainScreen>:
    RootWidget:
        id: root_widget

<RootWidget@BoxLayout>:
    orientation: "vertical"
    RecycleView:
        id: breadcrumb_view
        viewclass: "BreadcrumbWidget"
        data: []
        height: dp(30) if len(self.data) > 0 else 0
        size_hint_y: None
        RecycleBoxLayout:
            orientation: "horizontal"
            height: self.minimum_height
            size_hint_y: None
            default_size: None, dp(24)
    Widget:
        size_hint_y: dp(0.04)
    BoxLayout:
        size_hint_y: None
        height: dp(50)
        padding: [dp(12), dp(5), dp(12), dp(8)]
        spacing: dp(0)
        TextInput:
            id: filter_input
            multiline: False
            hint_text: app._('search', app.locale)
            padding: [dp(10), dp(8)]
            background_color: 0.95, 0.95, 0.95, 1
            on_text: root.on_filter_text(self.text)
    RecycleView:
        id: recycle_view
        viewclass: "RootItemWidget"
        size_hint_y: 1
        RecycleBoxLayout:
            default_size: None, app.theme.md3_button_height + dp(8)
            default_size_hint: 1, None
            size_hint_y: None
            height: self.minimum_height
            orientation: "vertical"
    Widget:
        size_hint_y: dp(0.04)
    BoxLayout:
        orientation: "horizontal"
        height: app.theme.md3_button_height + dp(8)
        size_hint_y: None
        spacing: dp(8)
        padding: [dp(8), 0, dp(8), 0]
        Widget:
            size_hint_x: 0.02
        Button:
            # Show "Add Language Pair" button when at root level
            text: app._("language_pair_add_title", app.locale) if (root.path == 'root') else ""
            opacity: 1.0 if (root.path == 'root') else 0
            disabled: False if (root.path == 'root') else True
            size_hint_x: 0.25 if (root.path == 'root') else 0.01
            on_release:
                root.add_language_pair()
        Button:
            # Show "Manage Dictionaries" button when viewing games (not root, not dictionaries)
            text: app._("dictionaries_manage_title", app.locale) if (root.path != 'root' and not root.path.startswith('assets/data/')) else ""
            opacity: 1.0 if (root.path != 'root' and not root.path.startswith('assets/data/')) else 0
            disabled: False if (root.path != 'root' and not root.path.startswith('assets/data/')) else True
            size_hint_x: 0.25 if (root.path != 'root' and not root.path.startswith('assets/data/')) else 0.01
            on_release:
                app.next_screen('dictionary_management_screen')
        Button:
            # Show "Add Category" button when viewing dictionaries (after language pair selected)
            text: app._("category_add_title", app.locale) if (root.path.startswith('assets/data/') and '/source.json' in root.path) else ""
            opacity: 1.0 if (root.path.startswith('assets/data/') and '/source.json' in root.path) else 0
            disabled: False if (root.path.startswith('assets/data/') and '/source.json' in root.path) else True
            size_hint_x: 0.25 if (root.path.startswith('assets/data/') and '/source.json' in root.path) else 0.01
            on_release:
                root.add_category()
        Widget:
            size_hint_x: 0.02
        Button:
            text: app._("button_settings", app.locale)
            size_hint_x: 0.3
            on_release:
                app.next_screen('language_screen')
        Widget:
            size_hint_x: 0.02
    Widget:
        size_hint_y: dp(0.08)

<RootItemWidget@BoxLayout>:
    orientation: "horizontal"
    spacing: dp(8)
    padding: [0, dp(4), 0, dp(4)]
    text: ""
    source: ""
    logo: ""
    store_path: ""
    route_path: ""
    locale_from: ""
    locale_to: ""
    category_id: ""
    category_name: ""
    Widget:
        size_hint_x: 0.05
    Button:
        text: app._('button_delete', app.locale)
        opacity: 1.0 if ((not root.route_path and root.category_id) or (root.locale_from and root.locale_to and not root.category_id and not root.route_path)) else 0
        disabled: False if ((not root.route_path and root.category_id) or (root.locale_from and root.locale_to and not root.category_id and not root.route_path)) else True
        size_hint_x: None
        width: self.texture_size[0] + dp(18) if ((not root.route_path and root.category_id) or (root.locale_from and root.locale_to and not root.category_id and not root.route_path)) else 0
        on_release:
            app.root.get_screen('main_screen').ids.root_widget.delete_category(root) if root.category_id else app.root.get_screen('main_screen').ids.root_widget.delete_language_pair(root)
    Label:
        text: app._(root.text, app.locale) if root.text.startswith('game_') else root.text
        size_hint_x: 0.4
    Button:
        text: app._('button_play', app.locale) if root.route_path else ""
        disabled: False if root.route_path else True
        opacity: 1.0 if root.route_path else 0
        size_hint_x: 0.4 if root.route_path else 0.01
        on_release:
            app.root.get_screen('main_screen').ids.root_widget.play_game(root)
    Button:
        text: app._('button_add_word', app.locale)
        opacity: 1.0 if (not root.route_path and root.category_id) else 0
        disabled: False if (not root.route_path and root.category_id) else True
        size_hint_x: None
        width: self.texture_size[0] + dp(18) if (not root.route_path and root.category_id) else 0
        on_release:
            app.root.get_screen('main_screen').ids.root_widget.add_vocabulary(root)
    Button:
        text: app._('button_select', app.locale)
        opacity: 1.0 if not root.route_path else 0
        size_hint_x: None
        width: self.texture_size[0] + dp(18) if not root.route_path else 0
        on_release:
            app.root.get_screen('main_screen').ids.root_widget.update_data(root)
    Widget:
        size_hint_x: 0.05

<BreadcrumbWidget@Button>:
    text: ""
    source: ""
    cursor: "hand"
    color: app.theme.md3_primary
    width: self.texture_size[0] + dp(20)
    size_hint_x: None
    background_normal: ""
    background_color: 0,0,0,0
    canvas.after:
        Color:
            rgba: app.theme.md3_secondary
        Triangle:
            points: (self.right - dp(5), self.y + dp(6), self.right - dp(2), self.center_y, self.right - dp(5), self.top - dp(6))
        Line:
            points: (self.x + dp(10), self.y - dp(1), self.right - dp(10), self.y - dp(1))
            width: 0.25
    on_release:
        app.root.get_screen('main_screen').ids.root_widget.load_breadcrumb(root.source)
