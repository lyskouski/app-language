<LanguageScreen>:
    LanguageWidget:
        id: language_widget

<LanguageWidget>:
    orientation: "vertical"
    padding: dp(20)
    spacing: dp(20)

    Label:
        text: "Select Language"
        font_size: sp(24)
        size_hint_y: None
        height: dp(60)
        text_size: self.width, None
        halign: "center"

    RecycleView:
        id: language_view
        viewclass: "LanguageItemWidget"
        size_hint_y: 1
        RecycleBoxLayout:
            default_size: None, dp(80)
            default_size_hint: 1, None
            size_hint_y: None
            height: self.minimum_height
            orientation: "vertical"
            spacing: dp(10)

<LanguageItemWidget@BoxLayout>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(80)
    padding: dp(10)
    spacing: dp(15)
    text: ""
    logo: ""
    locale: ""
    canvas.before:
        Color:
            rgba: app.md3_surface_container
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]

    Image:
        source: root.logo
        size_hint_x: None
        width: dp(60)
        allow_stretch: True
        keep_ratio: True

    Label:
        text: root.text
        text_size: self.width, None
        halign: "left"
        valign: "middle"
        font_size: sp(16)

    Button:
        text: "Select / Wybierz"
        size_hint_x: None
        width: dp(140)
        background_color: app.md3_primary
        color: app.md3_on_primary
        on_release:
            app.root.get_screen('language_screen').ids.language_widget.select_language(root.locale)
