#:kivy 2.0
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDLabel kivymd.uix.label.MDLabel
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton

<LanguageScreen@Screen>:
    LanguageWidget:
        id: language_widget

<LanguageWidget@MDBoxLayout>:
    orientation: "vertical"
    padding: dp(20)
    spacing: dp(20)

    MDLabel:
        text: "Select Language"
        font_style: "H4"
        size_hint_y: None
        height: dp(60)

    RecycleView:
        id: language_view
        viewclass: "LanguageItemWidget"
        size_hint_y: 1
        RecycleBoxLayout:
            default_size: None, dp(80)
            default_size_hint: 1, None
            size_hint_y: None
            height: self.minimum_height
            orientation: "vertical"
            spacing: dp(10)

<LanguageItemWidget@MDBoxLayout>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(80)
    padding: dp(10)
    spacing: dp(15)
    text: ""
    logo: ""
    locale: ""
    canvas.before:
        Color:
            rgba: 0.9, 0.9, 0.9, 0.1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]

    Image:
        source: root.logo
        size_hint_x: None
        width: dp(60)
        allow_stretch: True
        keep_ratio: True

    MDLabel:
        text: root.text
        halign: "left"
        valign: "middle"
        font_style: "Body1"
        size_hint_x: 1

    MDRaisedButton:
        text: "Select / Wybierz"
        size_hint_x: None
        width: dp(140)
        on_release:
            app.root.get_screen('language_screen').ids.language_widget.select_language(root.locale)
