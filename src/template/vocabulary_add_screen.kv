#:kivy 2.0
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDScrollView kivymd.uix.scrollview.MDScrollView
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDLabel kivymd.uix.label.MDLabel
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton
#:import MDFlatButton kivymd.uix.button.MDFlatButton

<VocabularyAddScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(16)

        # Header with title
        MDLabel:
            text: app._("vocab_add_title", app.locale)
            font_style: "H6"
            size_hint_y: None
            height: dp(32)

        # Form fields in scrollable container
        MDScrollView:
            size_hint_y: 1

            MDBoxLayout:
                orientation: 'vertical'
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height
                padding: [0, dp(8)]

                # Origin (source language word) - REQUIRED
                MDLabel:
                    text: app._("vocab_origin_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: origin_input
                    text: root.origin_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    on_text: root.origin_text = self.text

                # Translation (target language word) - REQUIRED
                MDLabel:
                    text: app._("vocab_translation_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: translation_input
                    text: root.translation_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    on_text: root.translation_text = self.text

                # Category - Pre-filled (read-only)
                MDLabel:
                    text: app._("vocab_category_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: category_input
                    text: root.category_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    readonly: True
                    disabled: True

                # Difficulty Level - Optional
                MDLabel:
                    text: app._("vocab_difficulty_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: difficulty_input
                    text: root.difficulty_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    input_filter: 'int'
                    hint_text: "0"
                    on_text: root.difficulty_text = self.text

                # Sound Path - Optional
                MDLabel:
                    text: app._("vocab_sound_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: sound_input
                    text: root.sound_path_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    hint_text: "e.g., assets/audio/word.mp3"
                    on_text: root.sound_path_text = self.text

                # Image Path - Optional
                MDLabel:
                    text: app._("vocab_image_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: image_input
                    text: root.image_path_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    hint_text: "e.g., assets/images/word.png"
                    on_text: root.image_path_text = self.text

                # Spacer at bottom of form
                Widget:
                    size_hint_y: None
                    height: dp(16)

        # Button group - fixed at bottom
        MDBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(48)
            spacing: dp(12)
            padding: [0, dp(8)]

            MDFlatButton:
                text: app._("button_cancel", app.locale) if hasattr(app, '_') else "Cancel"
                size_hint_x: 0.4
                height: dp(40)
                on_release: root.cancel()

            MDRaisedButton:
                text: app._("button_save", app.locale) if hasattr(app, '_') else "Save"
                size_hint_x: 0.6
                height: dp(40)
                on_release: root.save_vocabulary_item()
