<VocabularyAddScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)

        # Header
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            Label:
                text: app._("vocab_add_title", app.locale)
                font_size: sp(20)
                bold: True

        # Form fields
        ScrollView:
            size_hint_y: 0.8

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(10)
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(8), 0]

                # Origin (source language word) - REQUIRED
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    Label:
                        text: app._("vocab_origin_label", app.locale)
                        size_hint_y: None
                        height: dp(32)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: origin_input
                        text: root.origin_text
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        font_size: sp(18)
                        on_text: root.origin_text = self.text

                # Translation (target language word) - REQUIRED
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    Label:
                        text: app._("vocab_translation_label", app.locale)
                        size_hint_y: None
                        height: dp(32)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: translation_input
                        text: root.translation_text
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        font_size: sp(18)
                        on_text: root.translation_text = self.text

                # Category - Pre-filled (read-only)
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    Label:
                        text: app._("vocab_category_label", app.locale)
                        size_hint_y: None
                        height: dp(32)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: category_input
                        text: root.category_text
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        font_size: sp(16)
                        readonly: True
                        disabled: True
                        background_color: app.md3_surface_variant

                # Difficulty Level - Optional
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    Label:
                        text: app._("vocab_difficulty_label", app.locale)
                        size_hint_y: None
                        height: dp(32)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: difficulty_input
                        text: root.difficulty_text
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        font_size: sp(18)
                        input_filter: 'int'
                        hint_text: "0"
                        on_text: root.difficulty_text = self.text

                # Sound Path - Optional
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    Label:
                        text: app._("vocab_sound_label", app.locale)
                        size_hint_y: None
                        height: dp(32)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: sound_input
                        text: root.sound_path_text
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        font_size: sp(16)
                        hint_text: "e.g., assets/audio/word.mp3"
                        on_text: root.sound_path_text = self.text

                # Image Path - Optional
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(85)
                    spacing: dp(5)
                    Label:
                        text: app._("vocab_image_label", app.locale)
                        size_hint_y: None
                        height: dp(32)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: image_input
                        text: root.image_path_text
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        font_size: sp(16)
                        hint_text: "e.g., assets/images/word.png"
                        on_text: root.image_path_text = self.text

        # Buttons
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)
            padding: [0, dp(5)]

            Button:
                text: app._("button_cancel", app.locale) if hasattr(app, '_') else "Cancel"
                font_size: sp(18)
                size_hint_x: 0.3
                on_release: root.cancel()

            Widget:
                size_hint_x: 0.4

            Button:
                text: app._("button_save", app.locale) if hasattr(app, '_') else "Save"
                font_size: sp(18)
                size_hint_x: 0.3
                on_release: root.save_vocabulary_item()
