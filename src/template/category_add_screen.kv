<CategoryAddScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)

        # Header
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            Label:
                text: app._("category_add_title", app.locale)
                font_size: sp(20)
                bold: True

        # Form fields
        ScrollView:
            size_hint_y: 0.8

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(10)
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(8), 0]

                # Category Name - REQUIRED
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(105)
                    spacing: dp(5)
                    Label:
                        text: app._("category_name_label", app.locale)
                        size_hint_y: None
                        height: dp(36)
                        font_size: sp(16)
                        text_size: self.size
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: category_name_input
                        text: root.category_name_text
                        multiline: False
                        size_hint_y: None
                        height: dp(48)
                        font_size: sp(18)
                        hint_text: "e.g., verbs, dictionary, numbers, articulation"
                        on_text: root.category_name_text = self.text
                    Label:
                        text: "This name will be used to identify vocabulary items for this category"
                        font_size: sp(12)
                        size_hint_y: None
                        height: 20
                        color: app.md3_on_surface_variant
                        text_size: self.size
                        halign: 'left'
                        valign: 'top'
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)
            padding: [0, dp(5)]

            Button:
                text: app._("button_cancel", app.locale)
                font_size: sp(18)
                size_hint_x: 0.3
                on_release: root.cancel()

            Widget:
                size_hint_x: 0.4

            Button:
                text: app._("button_save", app.locale)
                font_size: sp(18)
                size_hint_x: 0.3
                on_release: root.save_category()
