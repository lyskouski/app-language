#:kivy 2.0
#:import MDBoxLayout kivymd.uix.boxlayout.MDBoxLayout
#:import MDScrollView kivymd.uix.scrollview.MDScrollView
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDLabel kivymd.uix.label.MDLabel
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton
#:import MDFlatButton kivymd.uix.button.MDFlatButton

<CategoryAddScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(16)

        # Header with title
        MDLabel:
            text: app._("category_add_title", app.locale)
            font_style: "H6"
            size_hint_y: None
            height: dp(32)

        # Form fields in scrollable container
        MDScrollView:
            size_hint_y: 1

            MDBoxLayout:
                orientation: 'vertical'
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height
                padding: [0, dp(8)]

                # Category Name - REQUIRED
                MDLabel:
                    text: app._("category_name_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: category_name_input
                    text: root.category_name_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    hint_text: "e.g., verbs, dictionary, numbers"
                    on_text: root.category_name_text = self.text
                MDLabel:
                    text: "Used to identify vocabulary items in this category"
                    font_style: "Caption"
                    size_hint_y: None
                    height: dp(20)
                    color: [0.5, 0.5, 0.5, 1]

                # Icon Path - Optional
                MDLabel:
                    text: app._("category_icon_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: icon_input
                    text: root.icon_path_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    hint_text: "e.g., assets/images/category_icon.png"
                    on_text: root.icon_path_text = self.text

                # Display Order - Optional
                MDLabel:
                    text: app._("category_order_label", app.locale)
                    size_hint_y: None
                    height: dp(20)
                    font_style: "Caption"
                MDTextField:
                    id: order_input
                    text: root.display_order_text
                    mode: "rectangle"
                    size_hint_y: None
                    height: dp(56)
                    input_filter: 'int'
                    hint_text: "0"
                    on_text: root.display_order_text = self.text

                # Spacer at bottom
                Widget:
                    size_hint_y: None
                    height: dp(16)

        # Button group - fixed at bottom
        MDBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(48)
            spacing: dp(12)
            padding: [0, dp(8)]

            MDFlatButton:
                text: app._("button_cancel", app.locale)
                size_hint_x: 0.4
                height: dp(40)
                on_release: root.cancel()

            MDRaisedButton:
                text: app._("button_save", app.locale)
                size_hint_x: 0.6
                height: dp(40)
                on_release: root.save_category()
